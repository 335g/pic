{
  "name": "pic-backend",
  "version": "1.0.0",
  "description": "pic API server — Cloudflare Workers + Hono + D1",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
